# Anthropic / Claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# Azure DevOps target org/project. Auth uses OAuth2 device-code flow against
# Microsoft's pre-registered Azure CLI client — no PAT or App Registration
# required. Optionally pin the tenant via AZURE_TENANT_ID; defaults to
# 'organizations' (any work/school account).
AZURE_DEVOPS_ORG=https://dev.azure.com/your-org
AZURE_DEVOPS_PROJECT=your-project
# AZURE_TENANT_ID=your-tenant-guid

# Server
PORT=3001
